case "$target_triplet" in {
    { "armeb-*-eabi*" "armeb-*-elf*"} {
	set mps2_aem_m_version "--model=mps2 --arch=armv7e-m --bigendian"
    }
    default {
	set mps2_aem_m_version "--model=mps2 --arch=armv7e-m"
    }
}
set startup_link_option "-Wl,-Ttext-segment=0x60000000"
load_board_description "arm-eabi-mps2"
